@prefix ex:   <http://example.org/okb#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# -----------------------------------------------------------------------------
# SHACL Shapes: Clinical Safety (EU MDR 2017/745, FDA CDS Guidance, WHO 2021)
# -----------------------------------------------------------------------------

# ---- Shape 1: Every DiagnosticRecommendation must have clinical evidence ----

ex:ClinicalEvidenceRequiredShape
    a sh:NodeShape ;
    sh:targetClass ex:DiagnosticRecommendation ;
    sh:property [
        sh:path ex:hasClinicalEvidence ;
        sh:minCount 1 ;
        sh:message "EU MDR Annex XV: AI diagnostic recommendation must reference clinical evidence [MDR 2017/745 Annex XV]" ;
    ] .

# ---- Shape 2: Clinical evidence must be complete ----------------------------

ex:ClinicalEvidenceShape
    a sh:NodeShape ;
    sh:targetClass ex:ClinicalEvidence ;
    sh:property [
        sh:path ex:evidenceSource ;
        sh:minCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:message "EU MDR Annex XV: Clinical evidence must include a source URI for clinical evaluation [MDR 2017/745 Annex XV]" ;
    ] ;
    sh:property [
        sh:path ex:evidenceLevel ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "EU MDR Annex XV: Clinical evidence must specify the level of evidence [MDR 2017/745 Annex XV]" ;
    ] .

# ---- Shape 3: Every DiagnosticRecommendation must have uncertainty report ---

ex:UncertaintyRequiredShape
    a sh:NodeShape ;
    sh:targetClass ex:DiagnosticRecommendation ;
    sh:property [
        sh:path ex:hasUncertaintyReport ;
        sh:minCount 1 ;
        sh:message "FDA CDS Guidance: AI diagnostic output must include uncertainty or confidence metrics [FDA-2022-D-1766]" ;
    ] .

# ---- Shape 4: Uncertainty report must be complete ---------------------------

ex:UncertaintyReportShape
    a sh:NodeShape ;
    sh:targetClass ex:UncertaintyReport ;
    sh:property [
        sh:path ex:confidenceScore ;
        sh:minCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message "FDA CDS Guidance: Uncertainty report must include a confidence score [FDA-2022-D-1766]" ;
    ] ;
    sh:property [
        sh:path ex:uncertaintyMethod ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "FDA CDS Guidance: Uncertainty report must specify the method used [FDA-2022-D-1766]" ;
    ] .

# ---- Shape 5: Every DiagnosticRecommendation must have cohort documentation -

ex:CohortDocumentationRequiredShape
    a sh:NodeShape ;
    sh:targetClass ex:DiagnosticRecommendation ;
    sh:property [
        sh:path ex:hasPatientCohort ;
        sh:minCount 1 ;
        sh:message "WHO AI Health Ethics: Training population demographics must be documented [WHO 2021, Sec.3.4]" ;
    ] .

# ---- Shape 6: Patient cohort must be complete -------------------------------

ex:PatientCohortShape
    a sh:NodeShape ;
    sh:targetClass ex:PatientCohortDescription ;
    sh:property [
        sh:path ex:cohortSize ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "WHO AI Health Ethics: Patient cohort must specify the cohort size [WHO 2021, Sec.3.4]" ;
    ] ;
    sh:property [
        sh:path ex:cohortDescription ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "WHO AI Health Ethics: Patient cohort must include a demographic description [WHO 2021, Sec.3.4]" ;
    ] .

# ---- Shape 7: Every DiagnosticRecommendation must have clinical review ------

ex:ClinicalReviewRequiredShape
    a sh:NodeShape ;
    sh:targetClass ex:DiagnosticRecommendation ;
    sh:property [
        sh:path ex:hasClinicalReview ;
        sh:minCount 1 ;
        sh:message "EU MDR Art.14(3): Clinical assessment by qualified professional required before acting on AI recommendation [MDR 2017/745 Art.14(3)]" ;
    ] .

# ---- Shape 8: Clinical review record must be complete -----------------------

ex:ClinicalReviewRecordShape
    a sh:NodeShape ;
    sh:targetClass ex:ClinicalReviewRecord ;
    sh:property [
        sh:path ex:reviewerQualification ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "EU MDR Art.14(3): Clinical review must identify the reviewer qualification [MDR 2017/745 Art.14(3)]" ;
    ] ;
    sh:property [
        sh:path ex:reviewTimestamp ;
        sh:minCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "EU MDR Art.14(3): Clinical review must include a timestamp [MDR 2017/745 Art.14(3)]" ;
    ] ;
    sh:property [
        sh:path ex:reviewDecision ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "EU MDR Art.14(3): Clinical review must record the review decision [MDR 2017/745 Art.14(3)]" ;
    ] .
