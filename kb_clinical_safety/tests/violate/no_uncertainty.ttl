@prefix ex:  <http://example.org/okb#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# -----------------------------------------------------------------------------
# Non-conformant evidence graph: missing uncertainty report
# This graph should FAIL validation, triggering exactly one violation
# on ex:UncertaintyRequiredShape (FDA CDS Guidance).
# -----------------------------------------------------------------------------

# ---- The AI diagnostic recommendation (no ex:hasUncertaintyReport link) -----

ex:diagnosis-2026-LC-0099
    a ex:DiagnosticRecommendation ;
    ex:icdOCode "8140/3 C34.1" ;
    ex:recommendedAction "Refer for confirmatory biopsy and PET-CT staging" ;
    ex:hasClinicalEvidence ex:evidence-nccn-099 ;
    ex:hasPatientCohort ex:cohort-099 ;
    ex:hasClinicalReview ex:review-099 .

# ---- Clinical evidence (complete) ------------------------------------------

ex:evidence-nccn-099
    a ex:ClinicalEvidence ;
    ex:evidenceSource "https://www.nccn.org/guidelines/guidelines-detail?category=1&id=1450"^^xsd:anyURI ;
    ex:evidenceLevel "Level I" .

# ---- Patient cohort description (complete) ----------------------------------

ex:cohort-099
    a ex:PatientCohortDescription ;
    ex:cohortSize "45000"^^xsd:integer ;
    ex:cohortDescription "Multi-ethnic adult population, age 40-85, NLST and LIDC-IDRI datasets" .

# ---- Clinical review record (complete) --------------------------------------

ex:review-099
    a ex:ClinicalReviewRecord ;
    ex:reviewerQualification "Board-certified thoracic oncologist" ;
    ex:reviewTimestamp "2026-03-27T09:15:00Z"^^xsd:dateTime ;
    ex:reviewDecision "confirmed" .
